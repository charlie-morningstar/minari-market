# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요.
#   cp .env.example .env
#
# .env 는 .gitignore 에 등록되어 있어 깃 저장소에 올라가지 않습니다.

# 세션/CSRF 서명에 쓰이는 비밀키. 아래 명령으로 만들어 붙여넣으세요.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex

# HTTPS(운영/ngrok) 환경이면 1 로. 로컬 http 개발 시에는 0.
COOKIE_SECURE=0

# 관리자 초기 계정(init_db.py 에서 사용)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
